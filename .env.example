# Copy this file to .env and fill in every blank value.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=srv578.hstgr.io
DB_PORT=3306
DB_NAME=u524585165_lifecare
DB_USER=u524585165_lifecare
DB_PASSWORD=
DB_POOL_SIZE=5

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=30

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080
APP_ENV=production

# ── Public backend URL (used as webhook callback base) ────────────────────────
PUBLIC_URL=https://lifecareapi-production.up.railway.app

# ── MTN Mobile Money Collection (sandbox) ────────────────────────────────────
# 1. Go to https://momodeveloper.mtn.com → Products → subscribe to "Collection"
# 2. Copy Primary Key → MTN_SUBSCRIPTION_KEY
# 3. Create API User:
#      curl -X POST https://sandbox.momoapi.mtn.com/v1_0/apiuser \
#        -H "X-Reference-Id: <any-uuid>" \
#        -H "Ocp-Apim-Subscription-Key: <MTN_SUBSCRIPTION_KEY>" \
#        -H "Content-Type: application/json" \
#        -d '{"providerCallbackHost":"lifecareapi-production.up.railway.app"}'
# 4. Create API Key:
#      curl -X POST https://sandbox.momoapi.mtn.com/v1_0/apiuser/<apiUser>/apikey \
#        -H "Ocp-Apim-Subscription-Key: <MTN_SUBSCRIPTION_KEY>"
MTN_SUBSCRIPTION_KEY=
MTN_API_USER=
MTN_API_KEY=
MTN_TARGET_ENV=sandbox
MTN_BASE_URL=https://ericssonbasicapi2.azure-api.net

# ── Flutterwave (card payments) ────────────────────────────────────────────────
# 1. Go to https://dashboard.flutterwave.com → Settings → API → copy Secret Key
# 2. Settings → Webhooks → set URL to PUBLIC_URL/v1/webhooks/flutterwave
#    and set a Secret Hash string (any random string) → FLUTTERWAVE_SECRET_HASH
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_SECRET_HASH=
