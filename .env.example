# Copy this file to .env and fill in every blank value.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=srv578.hstgr.io
DB_PORT=3306
DB_NAME=u524585165_lifecare
DB_USER=u524585165_lifecare
DB_PASSWORD=
DB_POOL_SIZE=5

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=30

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080
APP_ENV=production

# ── Public backend URL (used as webhook/IPN callback base) ───────────────────
PUBLIC_URL=https://lifecareapi-production.up.railway.app

# ── Pesapal payments ──────────────────────────────────────────────────────────
# 1. Sign up at https://pesapal.com → Developer / Sandbox
# 2. Copy Consumer Key and Consumer Secret from the dashboard
# 3. Set PESAPAL_BASE_URL to the sandbox URL for testing,
#    or https://pay.pesapal.com/v3 for production
# 4. Set webhook URL in Pesapal dashboard → IPN Settings:
#    PUBLIC_URL/v1/webhooks/pesapal
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_BASE_URL=https://cybqa.pesapal.com/pesapalv3
